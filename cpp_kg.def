Bootstrap: docker
From: continuumio/miniconda3:latest

%files
    environment.yml /app/environment.yml

%post
    apt-get update && apt-get install -y openjdk-11-jdk curl
    export JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64
    /opt/conda/bin/conda env create -f /app/environment.yml
    /opt/conda/bin/conda clean -a
    # Install Ollama binary
    curl -fsSL https://ollama.com/install.sh | sh
    mkdir -p /app

%environment
    export JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64
    export PATH=/opt/conda/envs/cpp_kg/bin:$PATH
    export CONDA_DEFAULT_ENV=cpp_kg

%runscript
    exec "$@"
