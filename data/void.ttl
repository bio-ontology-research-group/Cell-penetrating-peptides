<https://cppkg.bio2vec.net/dataset>
    a                    void:Dataset , dcat:Dataset ;
    dcterms:title        "CPP Knowledge Graph"@en ;
    dcterms:description  "A knowledge graph of cell-penetrating peptides (CPPs) integrating experimental uptake-mechanism data with biomedical ontologies (SIO, GO, ChEBI, CLO)."@en ;
    dcterms:creator      "Bio-Ontology Research Group, KAUST" ;
    dcterms:license      <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:created      "2025"^^xsd:gYear ;
    foaf:homepage        <https://cppkg.bio2vec.net/> ;

    void:uriSpace        "https://cppkg.bio2vec.net/dataset/" ;
    void:triples         159810 ;
    void:dataDump        <https://cppkg.bio2vec.net/data/CPP_KG.ttl> ;
    void:sparqlEndpoint  <https://cppkg.bio2vec.net/api/sparql> ;

    void:vocabulary      <http://semanticscience.org/resource/> ;
    void:vocabulary      <http://purl.obolibrary.org/obo/GO_> ;
    void:vocabulary      <http://purl.obolibrary.org/obo/CHEBI_> ;
    void:vocabulary      <http://purl.obolibrary.org/obo/CLO_> .
